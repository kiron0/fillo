{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "allowJs": false,
    "resolveJsonModule": true,
    "types": ["bun-types", "chrome", "node", "vitest/globals"]
  },
  "include": ["src", "scripts", "tests"],
  "exclude": ["dist", "node_modules"]
}
