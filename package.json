{
  "name": "fillo",
  "version": "0.1.4",
  "description": "Browser extension for scanning Google Forms, reusing saved profile values, and filling supported fields without auto-submitting.",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "bun run scripts/build.ts chrome",
    "build:all": "bun run build:chrome && bun run build:firefox",
    "build:chrome": "bun run scripts/build.ts chrome",
    "build:firefox": "bun run scripts/build.ts firefox",
    "dev": "bun --watch run scripts/build.ts chrome",
    "dev:chrome": "bun --watch run scripts/build.ts chrome",
    "dev:firefox": "bun --watch run scripts/build.ts firefox",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "bunx tsc --noEmit"
  },
  "devDependencies": {
    "@types/chrome": "^0.1.39",
    "@types/node": "^25.5.2",
    "bun-types": "^1.3.11",
    "jsdom": "^29.0.1",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  },
  "keywords": [
    "chrome-extension",
    "google-forms",
    "form-filler",
    "form-autofill",
    "google-form-filler",
    "google-form-autofill",
    "autofill",
    "productivity",
    "profiles",
    "presets",
    "chrome",
    "firefox",
    "manifest-v3"
  ]
}
