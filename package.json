{
  "name": "fillo",
  "version": "0.1.2",
  "description": "Chrome extension for scanning Google Forms, reusing saved profile values, and filling supported fields without auto-submitting.",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "bun run scripts/build.ts",
    "dev": "bun --watch run scripts/build.ts",
    "test": "bunx vitest run",
    "test:watch": "bunx vitest",
    "typecheck": "bunx tsc --noEmit"
  },
  "devDependencies": {
    "@types/chrome": "^0.1.39",
    "@types/node": "^24.5.2",
    "bun-types": "^1.3.2",
    "jsdom": "^29.0.1",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  }
}
